CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq50xx=y
CONFIG_TARGET_qualcommax_ipq50xx_DEVICE_xunison_exigo_d50=y

CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_UBIFS=y
CONFIG_TARGET_IMAGES_GZIP=y

CONFIG_KERNEL_BUILD_USER="D50"
CONFIG_KERNEL_BUILD_DOMAIN="local"

CONFIG_DEVEL=y
CONFIG_CCACHE=y

# CPU governor performance
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y

# WiFi ath11k
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_kmod-ath11k-pci=y
CONFIG_PACKAGE_ath11k-firmware-ipq5018=y
CONFIG_PACKAGE_ath11k-firmware-qcn6122=y
CONFIG_PACKAGE_ath11k-firmware-qcn9074=y

# Modem 5G MHI + RMNET
CONFIG_PACKAGE_kmod-mhi-bus=y
CONFIG_PACKAGE_kmod-mhi-pci-generic=y
CONFIG_PACKAGE_kmod-qcom-q6v5=y
CONFIG_PACKAGE_kmod-qcom-smem=y
CONFIG_PACKAGE_kmod-qcom-smd=y
CONFIG_PACKAGE_kmod-qcom-remoteproc=y
CONFIG_PACKAGE_kmod-qcom-rproc-common=y
CONFIG_PACKAGE_kmod-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_umbim=y
CONFIG_PACKAGE_uqmi=y

# USB3 + DWC3
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-dwc3-qcom=y

# Ethernet + NSS
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-qca-nss-gmac=y

# LuCI completo in italiano
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-it=y
CONFIG_PACKAGE_luci-i18n-firewall-it=y
CONFIG_PACKAGE_luci-i18n-opkg-it=y
CONFIG_PACKAGE_luci-i18n-system-it=y
CONFIG_PACKAGE_luci-i18n-network-it=y
CONFIG_PACKAGE_luci-i18n-wireless-it=y

# Tools utili
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_nano=y

# Filesystem
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ubifs=y
CONFIG_PACKAGE_kmod-fs-f2fs=y

# Busybox esteso
CONFIG_BUSYBOX_CUSTOM=y

# Rete
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# Debug
CONFIG_PACKAGE_strace=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ethtool=y

